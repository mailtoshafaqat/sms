<span class="app-icon @CssClass" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    @switch (Name.ToLowerInvariant())
    {
        case "add":
            <path d="M12 5v14M5 12h14"/>
            break;
        case "save":
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><path d="M17 21v-8H7v8M7 3v5h8"/>
            break;
        case "edit":
            <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/>
            break;
        case "delete":
            <path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/>
            break;
        case "back":
            <path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/>
            break;
        case "cancel":
            <path d="M18 6 6 18M6 6l12 12"/>
            break;
        case "close":
            <path d="M18 6 6 18M6 6l12 12"/>
            break;
        case "load":
            <path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 3v6h-6"/>
            break;
        case "logout":
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/>
            break;
        case "refresh":
            <path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/>
            break;
        case "test":
            <path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2"/><rect x="7" y="7" width="10" height="10" rx="2"/>
            break;
        case "upload":
            <path d="M12 3v12"/><path d="m7 8 5-5 5 5"/><path d="M5 21h14"/>
            break;
        case "download":
            <path d="M12 3v12"/><path d="m17 13-5 5-5-5"/><path d="M5 21h14"/>
            break;
        case "promote":
            <path d="M12 19V5"/><path d="m5 12 7-7 7 7"/>
            break;
        case "previous":
            <path d="M15 18l-6-6 6-6"/>
            break;
        case "next":
            <path d="M9 18l6-6-6-6"/>
            break;
        case "success":
            <path d="M20 6 9 17l-5-5"/>
            break;
        case "error":
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
            break;
        case "info":
            <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
            break;
        case "help":
            <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>
            break;
        case "dashboard":
            <rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/>
            break;
        case "users":
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            break;
        case "user":
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            break;
        case "classes":
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            break;
        case "chevron-down":
            <path d="m6 9 6 6 6-6"/>
            break;
        case "chevron-right":
            <path d="m9 18 6-6-6-6"/>
            break;
        case "attendance":
            <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            break;
        case "calendar":
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
            break;
        case "gate":
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            break;
        case "settings":
            <circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            break;
        case "warning":
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/>
            break;
        case "bell":
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            break;
        default:
            <circle cx="12" cy="12" r="10"/>
            break;
    }
    </svg>
</span>

@code {
    [Parameter] public string Name { get; set; } = "info";
    [Parameter] public string CssClass { get; set; } = string.Empty;
}
