@using Microsoft.Extensions.Options
@using SMS.Web.Configuration
@inject IOptions<AppBrandingOptions> BrandingOptions

<div class="company-brand @CssClass">
    <img src="@GetLogoUrl()"
         alt="@GetLogoAlt()"
         class="company-logo" />
    @if (ShowText)
    {
        <div class="company-brand-text">
            @if (!string.IsNullOrWhiteSpace(BrandingOptions.Value.CompanyName))
            {
                <strong>@BrandingOptions.Value.CompanyName</strong>
            }
            <a href="@BrandingOptions.Value.CompanyWhatsAppUrl" target="_blank" rel="noopener">
                @BrandingOptions.Value.CompanyPhoneDisplay
            </a>
        </div>
    }
</div>

@code {
    [Parameter] public bool ShowText { get; set; } = true;
    [Parameter] public string CssClass { get; set; } = string.Empty;

    private string GetLogoAlt() =>
        string.IsNullOrWhiteSpace(BrandingOptions.Value.CompanyName)
            ? "Company logo"
            : $"{BrandingOptions.Value.CompanyName} logo";

    private string GetLogoUrl()
    {
        var path = BrandingOptions.Value.CompanyLogoPath;
        return path.Contains('?', StringComparison.Ordinal) ? path : $"{path}?v=blue";
    }
}
