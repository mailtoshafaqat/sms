@using System.Security.Claims

@using SMS.Domain.Common

@implements IDisposable

@inject NavigationManager Navigation

@inject AuthenticationStateProvider AuthStateProvider



@ChildContent



@code {

    [Parameter] public RenderFragment? ChildContent { get; set; }



    private readonly SemaphoreSlim enforceLock = new(1, 1);



    protected override async Task OnInitializedAsync()

    {

        Navigation.LocationChanged += OnLocationChanged;

        await EnforceGateKeeperScopeAsync();

    }



    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>

        await EnforceGateKeeperScopeAsync();



    private async Task EnforceGateKeeperScopeAsync()

    {

        await enforceLock.WaitAsync();

        try

        {

            var auth = await AuthStateProvider.GetAuthenticationStateAsync();

            var user = auth.User;

            if (user.Identity?.IsAuthenticated != true)

            {

                return;

            }



            if (!user.IsInRole(RoleNames.GateKeeper)

                || user.IsInRole(RoleNames.Admin)

                || user.IsInRole(RoleNames.Coordinator)

                || user.IsInRole(RoleNames.Teacher))

            {

                return;

            }



            var path = new Uri(Navigation.Uri).AbsolutePath;

            if (!GateKeeperPaths.IsAllowed(path))

            {

                Navigation.NavigateTo("/attendance/gate", replace: true);

            }

        }

        finally

        {

            enforceLock.Release();

        }

    }



    public void Dispose()

    {

        Navigation.LocationChanged -= OnLocationChanged;

        enforceLock.Dispose();

    }

}

