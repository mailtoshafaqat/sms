@using SMS.Domain.Common

<AuthorizeView Roles="@RoleNames.GateKeeper">
    <Authorized Context="gateKeeperAuth">
        <AuthorizeView Roles="@($"{RoleNames.Admin},{RoleNames.Coordinator},{RoleNames.Teacher}")">
            <NotAuthorized Context="elevatedAuth">
                <GateKeeperNavMenu />
            </NotAuthorized>
            <Authorized Context="elevatedAuth">
                <StandardNavMenu />
            </Authorized>
        </AuthorizeView>
    </Authorized>
    <NotAuthorized Context="gateKeeperAuth">
        <StandardNavMenu />
    </NotAuthorized>
</AuthorizeView>
