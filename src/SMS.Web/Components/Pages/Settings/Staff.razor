@page "/settings/staff"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SMS.Application.DTOs
@using SMS.Application.Interfaces
@using SMS.Infrastructure.Identity
@inject ITeacherAssignmentService TeacherAssignmentService
@inject UserManager<ApplicationUser> UserManager
@inject ToastService Toast
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Staff & Sections</PageTitle>

<PageIntro Title="Staff & Section Assignment" Subtitle="Add staff with or without login. Staff without login still appear on Staff Attendance and can use a hardware device when connected." />

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-error">@loadError</div>
}
else if (isLoading)
{
    <div class="card"><p class="hint">Loading staff...</p></div>
}
else
{
    <details class="card collapsible-section" open="@(staffForm.Id > 0)">
        <summary>@(staffForm.Id > 0 ? "Edit staff member" : "Add staff member")</summary>
        <div class="collapsible-section-content">
        <p class="hint">
            Use this for teachers, peons, guards, accountants, and any employee.
            <strong>Login is optional</strong> — only create a user account if they need to sign in to SMS.
        </p>
        <div class="form-grid form-grid-2">
            <label class="form-field">
                <span class="field-label">First name</span>
                <InputText @bind-Value="staffForm.FirstName" class="field-input" />
            </label>
            <label class="form-field">
                <span class="field-label">Last name</span>
                <InputText @bind-Value="staffForm.LastName" class="field-input" />
            </label>
            <label class="form-field">
                <span class="field-label">Employee code</span>
                <InputText @bind-Value="staffForm.EmployeeCode" class="field-input" placeholder="Auto if blank, e.g. S001" />
            </label>
            <label class="form-field">
                <span class="field-label">Phone</span>
                <InputText @bind-Value="staffForm.Phone" class="field-input" />
            </label>
            <label class="form-field">
                <span class="field-label">Fingerprint user ID</span>
                <InputText @bind-Value="staffForm.FingerprintUserId" class="field-input" placeholder="Same as device user no." autocomplete="off" />
                <span class="field-hint">For hardware finger terminal (future)</span>
            </label>
            <label class="form-field">
                <span class="field-label">Face user ID</span>
                <InputText @bind-Value="staffForm.FaceUserId" class="field-input" placeholder="Same as device user no." autocomplete="off" />
                <span class="field-hint">For hardware face terminal (future)</span>
            </label>
            <label class="checkbox-field span-2">
                <InputCheckbox @bind-Value="staffForm.IsActive" />
                Active (shown on staff attendance)
            </label>
            @if (!string.IsNullOrWhiteSpace(staffForm.LinkedUserEmail))
            {
                <p class="hint span-2">Login linked: <code>@staffForm.LinkedUserEmail</code></p>
            }
            <div class="form-actions span-2">
                <button type="button" class="btn btn-icon" @onclick="SaveStaffAsync">
                    <AppIcon Name="save" />
                    <span>@(staffForm.Id > 0 ? "Save staff" : "Add staff")</span>
                </button>
                @if (staffForm.Id > 0)
                {
                    <button type="button" class="btn btn-secondary" @onclick="ResetStaffForm">Cancel edit</button>
                }
            </div>
        </div>
        </div>
    </details>

    <details class="card collapsible-section">
        <summary>Assign class teacher</summary>
        <div class="collapsible-section-content">
        @if (assignmentRows.Count == 0)
        {
            <p class="hint">No sections found. Add classes under Classes first.</p>
        }
        else
        {
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Class teacher</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in assignmentRows)
                        {
                            <tr>
                                <td>@row.ClassName</td>
                                <td>@row.SectionName</td>
                                <td>
                                    <InputSelect @bind-Value="row.SelectedTeacherId" class="field-select">
                                        <option value="0">— Not assigned —</option>
                                        @foreach (var teacher in teacherRows.Where(t => t.IsActive))
                                        {
                                            <option value="@teacher.Id">@teacher.FullName (@teacher.EmployeeCode)</option>
                                        }
                                    </InputSelect>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-secondary btn-icon" @onclick="() => SaveAssignmentAsync(row)">
                                        <AppIcon Name="save" />
                                        <span>Save</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        </div>
    </details>

    <details class="card collapsible-section">
        <summary>All staff (@teacherRows.Count)</summary>
        <div class="collapsible-section-content">
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Login</th>
                        <th>Sections</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (teacherRows.Count == 0)
                    {
                        <tr>
                            <td colspan="5">No staff yet. Use <strong>Add staff member</strong> above.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var teacher in teacherRows)
                        {
                            <tr>
                                <td>@teacher.FullName @(teacher.IsActive ? "" : "(inactive)")</td>
                                <td>@teacher.EmployeeCode</td>
                                <td>@(teacher.UserEmail ?? "— No login —")</td>
                                <td>@(teacher.AssignedSections.Count == 0 ? "—" : string.Join(", ", teacher.AssignedSections))</td>
                                <td>
                                    <button type="button" class="btn btn-secondary btn-icon-only" data-tooltip="Edit staff" @onclick="() => EditStaffAsync(teacher.Id)">
                                        <AppIcon Name="edit" />
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        </div>
    </details>

    <details class="card collapsible-section">
        <summary>Link login to existing staff (optional)</summary>
        <div class="collapsible-section-content form-grid">
        <p class="hint span-2">
            If you already created a <strong>Teacher</strong> user under User Accounts, link it here to connect login with the staff record.
            Or add staff above first without login, then create a user later and link.
        </p>
        <label>
            User account
            <InputSelect @bind-Value="linkUserId" class="field-select">
                <option value="">Select user...</option>
                @foreach (var user in teacherUsers)
                {
                    <option value="@user.Id">@user.Email</option>
                }
            </InputSelect>
        </label>
        <label>First name <InputText @bind-Value="linkFirstName" class="field-input" /></label>
        <label>Last name <InputText @bind-Value="linkLastName" class="field-input" /></label>
        <div class="actions span-2">
            <button type="button" class="btn btn-icon" @onclick="LinkUserAsync">
                <AppIcon Name="add" />
                <span>Create / update teacher profile from user</span>
            </button>
        </div>
        </div>
    </details>
}

@code {
    private List<SectionAssignmentRow> assignmentRows = [];
    private List<TeacherDisplayRow> teacherRows = [];
    private List<ApplicationUser> teacherUsers = [];
    private StaffMemberFormDto staffForm = new();
    private string linkUserId = string.Empty;
    private string linkFirstName = string.Empty;
    private string linkLastName = string.Empty;
    private bool isLoading = true;
    private string? loadError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            var assignments = await TeacherAssignmentService.GetSectionAssignmentsAsync();
            assignmentRows = assignments.Select(x => new SectionAssignmentRow
            {
                SectionId = x.SectionId,
                ClassName = x.ClassName,
                SectionName = x.SectionName,
                SelectedTeacherId = x.TeacherId ?? 0
            }).ToList();

            var teachers = await TeacherAssignmentService.GetTeachersAsync();
            teacherRows = [];

            foreach (var teacher in teachers)
            {
                string? email = null;
                if (!string.IsNullOrWhiteSpace(teacher.UserId))
                {
                    email = (await UserManager.FindByIdAsync(teacher.UserId))?.Email;
                }

                teacherRows.Add(new TeacherDisplayRow(
                    teacher.Id,
                    teacher.EmployeeCode,
                    teacher.FullName,
                    email,
                    teacher.IsActive,
                    teacher.AssignedSections));
            }

            teacherUsers = [];
            var users = await UserManager.Users.OrderBy(x => x.Email).ToListAsync();
            foreach (var user in users)
            {
                if (await UserManager.IsInRoleAsync(user, "Teacher"))
                {
                    teacherUsers.Add(user);
                }
            }
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveStaffAsync()
    {
        try
        {
            await TeacherAssignmentService.SaveStaffMemberAsync(staffForm);
            Toast.Success(staffForm.Id > 0 ? "Staff member saved." : "Staff member added.");
            ResetStaffForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
    }

    private async Task EditStaffAsync(int teacherId)
    {
        var member = await TeacherAssignmentService.GetStaffMemberAsync(teacherId);
        if (member is null)
        {
            Toast.Error("Staff member not found.");
            return;
        }

        if (!string.IsNullOrWhiteSpace(member.LinkedUserId))
        {
            member.LinkedUserEmail = (await UserManager.FindByIdAsync(member.LinkedUserId))?.Email;
        }

        staffForm = member;
        await InvokeAsync(StateHasChanged);
    }

    private void ResetStaffForm() => staffForm = new StaffMemberFormDto();

    private async Task SaveAssignmentAsync(SectionAssignmentRow row)
    {
        try
        {
            await TeacherAssignmentService.AssignSectionTeacherAsync(
                row.SectionId,
                row.SelectedTeacherId > 0 ? row.SelectedTeacherId : null);
            Toast.Success("Section assignment saved.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
    }

    private async Task LinkUserAsync()
    {
        if (string.IsNullOrWhiteSpace(linkUserId))
        {
            Toast.Error("Select a user.");
            return;
        }

        if (string.IsNullOrWhiteSpace(linkFirstName) || string.IsNullOrWhiteSpace(linkLastName))
        {
            Toast.Error("Enter first and last name.");
            return;
        }

        try
        {
            await TeacherAssignmentService.EnsureTeacherProfileAsync(linkUserId, linkFirstName, linkLastName);
            Toast.Success("Teacher profile linked.");
            linkUserId = string.Empty;
            linkFirstName = string.Empty;
            linkLastName = string.Empty;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
    }

    private sealed class SectionAssignmentRow
    {
        public int SectionId { get; init; }
        public string ClassName { get; init; } = string.Empty;
        public string SectionName { get; init; } = string.Empty;
        public int SelectedTeacherId { get; set; }
    }

    private sealed record TeacherDisplayRow(
        int Id,
        string EmployeeCode,
        string FullName,
        string? UserEmail,
        bool IsActive,
        IReadOnlyList<string> AssignedSections);
}
