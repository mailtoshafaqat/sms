@page "/attendance/gate"
@layout KioskLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using SMS.Application.Interfaces
@using SMS.Web.Services
@inject ILocalBiometricService LocalBiometricService
@inject IJSRuntime Js
@inject ToastService Toast
@implements IAsyncDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Attendance Gate</PageTitle>

<div class="gate-kiosk">
    <header class="gate-kiosk-header">
        <h1>Attendance Gate</h1>
        <p>Stand in front of the camera — attendance is captured automatically</p>
        @if (enrolledCount > 0)
        {
            <p class="gate-kiosk-enrolled">@enrolledCount face(s) enrolled for gate</p>
            <p class="gate-kiosk-enrolled-hint">For best results on this phone, enroll the face on this same device (Local Biometric Test).</p>
        }
    </header>

    @if (needsHttps)
    {
        <div class="gate-kiosk-secure-alert" role="alert">
            <p><strong>Camera blocked on HTTP.</strong> On a phone, open this secure link instead:</p>
            <p class="gate-kiosk-secure-url"><a href="@secureGateUrl">@secureGateUrl</a></p>
            <p class="gate-kiosk-secure-hint">Chrome will warn about the certificate — tap <strong>Advanced</strong> → <strong>Proceed</strong>, then allow camera. Install the PWA from this HTTPS link (not HTTP).</p>
        </div>
    }
    else if (enrolledCount == 0)
    {
        <div class="gate-kiosk-secure-alert" role="alert">
            <p><strong>No faces enrolled.</strong> Admin must enroll students at <strong>Attendance → Local Biometric Test</strong> first.</p>
        </div>
    }

    <div id="gate-error-only" class="gate-kiosk-error-only" hidden role="alert"></div>

    <div class="gate-kiosk-video-wrap idle" id="gate-video-wrap">
        <video id="gate-face-video" autoplay playsinline muted class="gate-kiosk-video"></video>
        <div class="gate-kiosk-overlay">
            <div class="gate-kiosk-icon" id="gate-frame-icon"></div>
            <p class="gate-kiosk-frame-label" id="gate-frame-label"></p>
        </div>
    </div>

    <div class="gate-kiosk-actions">
        @if (isStarting)
        {
            <p class="gate-kiosk-status muted">Starting camera…</p>
        }
        else if (!cameraRunning)
        {
            <button class="btn btn-lg" type="button" @onclick="StartCameraAsync">Retry camera</button>
        }
        else
        {
            <button class="btn btn-secondary btn-lg" type="button" @onclick="SwitchCameraAsync">Switch camera</button>
            <button class="btn btn-lg" type="button" @onclick="ScanOnceAsync" disabled="@isScanning">@(isScanning ? "Scanning…" : "Scan now")</button>
        }
        <a class="btn btn-secondary btn-lg" href="/">Exit</a>
    </div>
</div>

@code {
    private DotNetObjectReference<Gate>? dotNetRef;
    private string? message;
    private bool isError;
    private bool lastSuccess;
    private bool cameraRunning;
    private bool isStarting;
    private bool isScanning;
    private bool needsHttps;
    private bool faceSeen;
    private int enrolledCount;
    private string secureGateUrl = string.Empty;
    private string facingMode = "user";
    private DateTime lastStatusAt = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        var enrollments = await LocalBiometricService.GetFaceEnrollmentsAsync();
        enrolledCount = enrollments.Count;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || cameraRunning || isStarting || needsHttps)
        {
            return;
        }

        await InitializeGateAsync();
    }

    private async Task InitializeGateAsync()
    {
        try
        {
            dotNetRef ??= DotNetObjectReference.Create(this);

            var isSecure = await Js.InvokeAsync<bool>("smsPwaIsSecureContext");
            if (!isSecure)
            {
                secureGateUrl = await Js.InvokeAsync<string>("smsGateGetSecureUrl");
                needsHttps = true;
                SetMessage("Open the HTTPS link above to enable the camera on your phone.", true);
                await InvokeAsync(StateHasChanged);
                return;
            }

            isStarting = true;
            await InvokeAsync(StateHasChanged);
            await StartCameraAsync();
        }
        catch (Exception ex)
        {
            isStarting = false;
            SetMessage(ex.Message, true);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StartCameraAsync()
    {
        if (dotNetRef is null)
        {
            return;
        }

        try
        {
            isStarting = true;
            await Js.InvokeVoidAsync("smsGateStart", dotNetRef, "gate-face-video", facingMode, 2000);
            cameraRunning = true;
            SetMessage(enrolledCount == 0
                ? "Camera on — enroll students first, then refresh this page."
                : "Gate active — first scan marks IN, second marks OUT.", enrolledCount == 0);
        }
        catch (JSException ex)
        {
            cameraRunning = false;
            SetMessage(ex.Message, true);
        }
        finally
        {
            isStarting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public Task OnGateScanStatusAsync(bool faceDetected, bool success, string statusMessage)
    {
        return InvokeAsync(() =>
        {
            faceSeen = faceDetected;

            if (string.IsNullOrWhiteSpace(statusMessage))
            {
                StateHasChanged();
                return;
            }

            lastStatusAt = DateTime.UtcNow;
            SetMessage(statusMessage, !success, success: success);

            StateHasChanged();
        });
    }

    private async Task ScanOnceAsync()
    {
        if (dotNetRef is null || !cameraRunning)
        {
            return;
        }

        isScanning = true;
        try
        {
            await Js.InvokeVoidAsync("smsGateScanOnce", dotNetRef, "gate-face-video");
        }
        catch (JSException ex)
        {
            SetMessage(ex.Message, true);
        }
        finally
        {
            isScanning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SwitchCameraAsync()
    {
        if (dotNetRef is null)
        {
            return;
        }

        facingMode = facingMode == "user" ? "environment" : "user";
        try
        {
            await Js.InvokeVoidAsync("smsGateSwitchCamera", dotNetRef, "gate-face-video", facingMode, 2000);
            SetMessage(facingMode == "user" ? "Using front camera." : "Using back camera.", false);
            await InvokeAsync(StateHasChanged);
        }
        catch (JSException ex)
        {
            SetMessage(ex.Message, true);
        }
    }

    private void SetMessage(string text, bool error, bool success = false)
    {
        message = text;
        isError = error;
        lastSuccess = success && !error;
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();

        try
        {
            await Js.InvokeVoidAsync("smsGateStop");
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
